{{!< default}} 
<div class="container mx-auto">

    {{#match pagination.page "==" 1}}

    {{#get "tags" limit="5" include="count.posts" order="count.posts desc"}}

    {{#if tags}}
    {{!-- Show tags only on the first page --}}
    <div class="mb-28 mt-20 flex flex-wrap gap-5 justify-center">
        {{#foreach tags}}
            <a href="{{url}}"
                class="inline-flex justify-center items-center gap-2 whitespace-nowrap rounded-full bg-primary border border-primary dark:border-primary-dark px-4 py-2 text-sm font-medium tracking-wide text-on-primary transition hover:opacity-75 text-center focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary active:opacity-100 active:outline-offset-0 disabled:opacity-75 disabled:cursor-not-allowed dark:bg-primary-dark dark:text-on-primary-dark dark:focus-visible:outline-primary-dark">
            {{> "icons/tag" class="size-4 "}}
                {{name}}
            </a>
        {{/foreach}}
    </div>

    {{/if}}

    {{/get}}

    {{/match}}

    {{!-- Posts --}}
    {{> "layout/posts" posts=posts layout=@custom.posts_grid_layout }}

    <div class="mt-20"> {{pagination}} </div>

</div>