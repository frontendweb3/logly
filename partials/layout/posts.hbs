
{{!-- Reusable wrapper for rendering post cards in grid or stacked layout. --}}
{{#if posts.length}}

<div class="container mx-auto px-6 py-10 lg:py-12 lg:px-8">
    <div class="grid gap-5 lg:gap-7 {{#match layout "three_columns"}} lg:grid-cols-3 {{else}} lg:grid-cols-2 {{/match}}">
        {{#foreach posts}}
            {{> "cards/card" }}
        {{/foreach}}
    </div>
</div>

{{/if}}