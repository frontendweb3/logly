{{#if isSecondary}}

<div class="flex w-full flex-row items-center justify-center gap-2">
    {{#foreach navigation type='secondary'}}
    {{#link aria-label="Navigate to {{label}} page" href=(url) class="items-center gap-3 px-2 py-3 text-center text-sm
    transition-colors hover:underline hover:underline-offset-4" }} {{label}}
    {{/link}}
    {{/foreach}}
</div>

{{else}} {{!-- Main sidebar navigation --}}

<div class="flex w-full flex-col list-none space-y-5">
    {{#foreach navigation}}
    {{#link aria-label="Navigate to {{label}} page" activeClass="bg-primary/20 dark:hover:bg-primary-dark/10"
    class="group w-full
    flex items-center flex-row gap-2 h-10 px-3 py-2.5
    text-sm font-medium
    text-on-surface underline-offset-2
    hover:bg-primary/5 hover:text-on-surface-strong
    dark:text-on-surface-dark
    dark:hover:bg-primary-dark/10 dark:hover:text-on-surface-dark-strong" href=(url) }}
    <span
        class="bg-on-secondary-dark/30  dark:bg-on-secondary/30 group-hover:bg-on-secondary/30 group-hover:dark:bg-on-secondary-dark/30 h-2 w-2 rounded-full transition-colors"></span>
    <span class="text-sm font-medium"> {{label}} </span>
    {{/link}}
    {{/foreach}}
</div>

{{/if}}